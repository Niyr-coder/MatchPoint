NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Canonical public URL (no trailing slash). Used to build the OAuth callback
# URL and to auto-derive the cookie domain so PKCE auth works regardless of
# whether the user arrives via www or the apex domain.
# Example: https://matchpoint.top
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Public app URL — used to build invite links and other absolute URLs.
# Must match NEXT_PUBLIC_SITE_URL in most deployments.
# Example: https://matchpoint.top
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Optional overrides for the Supabase cookie domain (normally auto-derived
# from NEXT_PUBLIC_SITE_URL). Set these only if you need explicit control.
# NEXT_PUBLIC_COOKIE_DOMAIN=matchpoint.top  # browser client
# COOKIE_DOMAIN=matchpoint.top              # server client
